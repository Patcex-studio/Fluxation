# Repository root: keep only these directories and .gitignore
/*
!/.gitignore
!/adaptiflux-core/
!/adaptiflux-optim/
!/custom_optim/

# Ignore common build artifacts inside the allowed directories
**/target/
**/Cargo.lock
**/*.rs.bk
**/*.log
**/*.prof
**/*.json

# Ignore IDE and OS files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore virtual environments and local folders
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/